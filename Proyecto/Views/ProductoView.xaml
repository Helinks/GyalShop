<UserControl x:Class="Proyecto.Views.ProductoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LISTADO -->
        <DataGrid x:Name="dgProductos"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="dgProducts_SelectionChanged"
                  Margin="0,0,20,0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding IdProducto}" Width="20"/>
                <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="100"/>
                <DataGridTextColumn Header="Categoria" Binding="{Binding IdCategoriaProducto.NombreCategoria}" Width="70"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadProducto}" Width="70"/>
                <DataGridTextColumn Header="Precio" Binding="{Binding PrecioProducto}" Width="50"/>
                <DataGridTextColumn Header="Descuento" Binding="{Binding DescuentoProducto}" Width="70"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- FORMULARIO -->
        <StackPanel Grid.Column="1" Margin="20" >

            <TextBlock Text="Gestión de Productos"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Nombre -->
            <TextBlock Text="Nombre de producto" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNombre"
                     Height="35"
                     Margin="0,0,0,12"/>
            
            <TextBlock Text="Cantidad de producto" Margin="0,0,0,5"/>
            <TextBox x:Name="txtCantidad"
         Height="35"
         Margin="0,0,0,12"/>
            
            <TextBlock Text="Precio de producto" Margin="0,0,0,5"/>
            <TextBox x:Name="txtPrecio"
Height="35"
Margin="0,0,0,12"/>
            <TextBlock Text="Descuento de producto" Margin="0,0,0,5"/>
            <TextBox x:Name="txtDescuento"
Height="35"
Margin="0,0,0,12"/>

            <TextBlock Text="Categoria de producto" Margin="0,0,0,5"/>
            <ComboBox x:Name="CBCategoria"
                      Height ="35" 
                      Margin="0,0,0,12"
                      DisplayMemberPath="NombreCategoria"
                      SelectedValuePath="IdCategoria"/>



            <!-- Botones -->
            <StackPanel Orientation="Horizontal">

                <Button Content="Guardar"
                        x:Name="BtnGuardar"
                        Click="BtnGuardar_Click"
                        Width="100"
                        Margin="0,0,10,0"/>
                <Button Content="Cancelar"
                        x:Name="BtnCancelar"
                        Click="BtnCancelar_Click"
                        Width="100"
                        Margin="0,0,10,0"
                        Visibility="Collapsed"/>

                <Button Content="Actualizar"
                        x:Name="BtnActualizar"
                        Click="BtnActualizar_Click"
                        Width="100"
                        Margin="0,0,10,0"
                        Visibility="Collapsed"/>

                <Button Content="Eliminar"
                        x:Name="BtnEliminar"
                        Click="BtnEliminar_Click"
                        Width="100"
                        Visibility="Collapsed"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</UserControl>