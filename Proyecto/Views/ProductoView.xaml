<UserControl x:Class="Proyecto.Views.ProductoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded"
             Background="#F4F6FA">

    <UserControl.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#7B1330"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#6B7280"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#B91C1C"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#7B1330"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="58"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.4*"/>
            <ColumnDefinition Width="1.4*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,18,0"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DockPanel>

                <TextBlock Text="Listado de productos"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#111827"
                           Margin="0,0,0,14"
                           DockPanel.Dock="Top"/>

                <DataGrid x:Name="dgProductos"
                          SelectionChanged="dgProducts_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Id"
                                            Binding="{Binding IdProducto}"
                                            Width="60"/>

                        <DataGridTextColumn Header="Producto"
                                            Binding="{Binding NombreProducto}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Categoría"
                                            Binding="{Binding IdCategoriaProducto.NombreCategoria}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Cantidad"
                                            Binding="{Binding CantidadProducto}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Precio"
                                            Binding="{Binding PrecioProducto, StringFormat=$ {0:N0}}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Desc."
                                            Binding="{Binding DescuentoProducto}"
                                            Width="70"/>

                        <DataGridTemplateColumn Header="Estado" Width="95">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="6,2"
                                            CornerRadius="8"
                                            HorizontalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Inactivo"/>
                                                    <Setter Property="Foreground" Value="#B91C1C"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EstaActivo}" Value="True">
                                                            <Setter Property="Text" Value="Activo"/>
                                                            <Setter Property="Foreground" Value="#047857"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Imagen"
                                                Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Padding="2"
                                            Width="58"
                                            Height="58"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <Image Source="{Binding ImagenProducto}"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </DockPanel>

        </Border>

        <Border Grid.Column="1"
                Background="White"
                CornerRadius="18"
                Padding="18"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Height="640"
                Width="300">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel>

                    <TextBlock Text="Gestión de productos"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Nombre de producto"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="txtNombre"/>

                    <TextBlock Text="Cantidad de producto"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="txtCantidad"/>

                    <TextBlock Text="Precio de producto"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="txtPrecio"/>

                    <TextBlock Text="Descuento de producto"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="txtDescuento"/>

                    <TextBlock Text="Categoría de producto"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="CBCategoria"
                              DisplayMemberPath="NombreCategoria"
                              SelectedValuePath="IdCategoria"/>

                    <TextBlock Text="Imagen del producto"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"/>

                    <Button Content="Seleccionar imagen"
                            x:Name="BtnSeleccionarImagen"
                            Click="BtnSeleccionarImagen_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="150"
                            HorizontalAlignment="Left"/>

                    <TextBlock x:Name="txtRutaImagen"
                               TextWrapping="Wrap"
                               Foreground="#6B7280"
                               FontSize="12"
                               Margin="0,0,0,10"/>

                    <Border BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="8"
                            Background="#FAFAFA"
                            Margin="0,0,0,12">

                        <Grid Height="130">
                            <Image x:Name="imgPreview"
                                   Stretch="Uniform"/>
                        </Grid>

                    </Border>

                    <WrapPanel HorizontalAlignment="Left">
                        <Button Content="Guardar"
                                x:Name="BtnGuardar"
                                Click="BtnGuardar_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="92"/>

                        <Button Content="Cancelar"
                                x:Name="BtnCancelar"
                                Click="BtnCancelar_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="92"
                                Visibility="Collapsed"/>

                        <Button Content="Actualizar"
                                x:Name="BtnActualizar"
                                Click="BtnActualizar_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="100"
                                Visibility="Collapsed"/>

                        <Button Content="Inhabilitar"
                                x:Name="BtnInhabilitar"
                                Click="BtnInhabilitar_Click"
                                Style="{StaticResource DangerButtonStyle}"
                                Width="92"
                                Visibility="Collapsed"/>
                    </WrapPanel>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>

</UserControl>