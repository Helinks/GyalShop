<UserControl x:Class="Proyecto.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1400"
    Height="800">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Border Background="#5A0D24">

            <StackPanel>

                <TextBlock Text="GYALSHOP"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="20"/>

                <Button Content="Inicio"
                        Style="{StaticResource MenuButton}"
                        Click="BtnHome_Click"/>

                <Button Content="Usuarios"
                        Style="{StaticResource MenuButton}"
                        Click="BtnUsers_Click"/>

                <Button Content="Productos"
                        Style="{StaticResource MenuButton}"
                        Click="BtnProducts_Click"/>

                <Button Content="Cerrar sesión"
                        Style="{StaticResource MenuButton}"
                        Click="BtnLogout_Click"/>

            </StackPanel>

        </Border>

        <!-- 🔥 CONTENIDO -->
        <ContentControl x:Name="MainContent"
                        Grid.Column="1"/>

    </Grid>
</UserControl>