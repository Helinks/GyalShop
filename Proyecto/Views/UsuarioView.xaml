<UserControl x:Class="Proyecto.Views.UsuarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LISTADO -->
        <DataGrid x:Name="dgUsuarios"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="dgUsuarios_SelectionChanged"
                  Margin="0,0,20,0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdUsuario}" Width="60"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding NombreUsuario}"/>
                <DataGridTextColumn Header="Correo" Binding="{Binding Correo}"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoUsuario.IdTipo}"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding EstaActivo}"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- FORMULARIO -->
        <StackPanel Grid.Column="1" Margin="20">

            <TextBlock Text="Gestión de Usuarios"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Nombre -->
            <TextBlock Text="Nombre" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNombre"
                     Height="35"
                     Margin="0,0,0,12"/>

            <!-- Correo -->
            <TextBlock Text="Correo" Margin="0,0,0,5"/>
            <TextBox x:Name="txtCorreo"
                     Height="35"
                     Margin="0,0,0,12"/>

            <!-- Password -->
            <TextBlock Text="Contraseña" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword"
                         Height="35"
                         Margin="0,0,0,12"/>

            <!-- Teléfono -->
            <TextBlock Text="Teléfono" Margin="0,0,0,5"/>
            <TextBox x:Name="txtTelefono"
                     Height="35"
                     Margin="0,0,0,12"/>

            <!-- Dirección -->
            <TextBlock Text="Dirección" Margin="0,0,0,5"/>
            <TextBox x:Name="txtDireccion"
                     Height="35"
                     Margin="0,0,0,12"/>

            <!-- Tipo usuario -->
            <TextBlock Text="Tipo (1 Admin / 2 Cliente)" Margin="0,0,0,5"/>
            <TextBox x:Name="txtTipo"
                     Height="35"
                     Margin="0,0,0,20"/>

            <!-- Botones -->
            <StackPanel Orientation="Horizontal">

                <Button Content="Guardar"
                        Click="BtnGuardar_Click"
                        Width="100"
                        Margin="0,0,10,0"/>

                <Button Content="Actualizar"
                        Click="BtnActualizar_Click"
                        Width="100"
                        Margin="0,0,10,0"/>

                <Button Content="Eliminar"
                        Click="BtnEliminar_Click"
                        Width="100"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</UserControl>