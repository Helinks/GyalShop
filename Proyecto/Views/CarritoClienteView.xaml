<UserControl x:Class="Proyecto.Views.CarritoClienteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit">

    <Grid Margin="20" Background="#F3F4F6">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- PRODUCTO SELECCIONADO -->
        <Border x:Name="bdProducto"
                Grid.Column="0"
                Margin="0,0,15,0"
                Background="White"
                CornerRadius="18"
                Padding="24"
                BorderBrush="#E8DCE1"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Producto seleccionado"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#5A0D24"
                           Margin="0,0,0,14"/>

                <TextBlock Text="Aquí se muestra el producto que enviaste desde Home."
                           Foreground="#6B7280"
                           Margin="0,0,0,18"
                           TextWrapping="Wrap"/>

                <TextBlock Text="Nombre"
                           FontWeight="Bold"
                           Foreground="#5A0D24"/>
                <TextBlock x:Name="txtNombreProducto"
                           Text="-"
                           Margin="0,4,0,12"
                           FontSize="16"
                           Foreground="#111827"
                           TextWrapping="Wrap"/>

                <TextBlock Text="Precio unitario"
                           FontWeight="Bold"
                           Foreground="#5A0D24"/>
                <TextBlock x:Name="txtPrecioProducto"
                           Text="-"
                           Margin="0,4,0,12"
                           FontSize="16"
                           Foreground="#111827"/>

                <TextBlock Text="Cantidad"
                           FontWeight="Bold"
                           Foreground="#5A0D24"/>
                <xctk:IntegerUpDown x:Name="numCantidad"
                                    Width="120"
                                    Height="35"
                                    Minimum="1"
                                    Maximum="100"
                                    Value="1"
                                    Increment="1"
                                    Margin="0,6,0,12"/>

                <TextBlock Text="Total del producto"
                           FontWeight="Bold"
                           Foreground="#5A0D24"/>
                <TextBlock x:Name="txtTotalProducto"
                           Text="$ 0"
                           Margin="0,4,0,18"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#7B1330"/>

                <Button x:Name="BtnAgregarActualizar"
                        Content="Agregar al carrito"
                        Height="44"
                        Margin="0,0,0,10"
                        Background="#7B1330"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnAgregarActualizar_Click"/>

                <Button Content="Volver"
                        Height="44"
                        Background="White"
                        BorderBrush="#CFA3B1"
                        BorderThickness="2"
                        Foreground="#7B1330"
                        FontWeight="Bold"
                        Click="BtnVolver_Click"/>
            </StackPanel>
        </Border>

        <!-- CARRITO -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="18"
                Padding="24"
                BorderBrush="#E8DCE1"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Tu carrito"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#5A0D24"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="txtUsuarioActual"
                               Text="Usuario:"
                               Foreground="#6B7280"
                               Margin="0,0,0,4"/>

                    <TextBlock x:Name="txtEstadoCarrito"
                               Text=""
                               Foreground="#7B1330"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>
                </StackPanel>

                <DataGrid x:Name="dgCarrito"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Margin="0,0,0,14">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="*"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="90"/>
                        <DataGridTextColumn Header="Precio" Binding="{Binding PrecioUnidad, StringFormat=$ {0:N0}}" Width="110"/>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=$ {0:N0}}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2"
                        Background="#FAFAFA"
                        CornerRadius="14"
                        Padding="18"
                        BorderBrush="#E8DCE1"
                        BorderThickness="1">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Resumen"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#5A0D24"
                                       Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtCantidadItems"
                                       Text="0 productos"
                                       Foreground="#374151"/>
                            <TextBlock x:Name="txtTotalCarrito"
                                       Text="Total: $ 0"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#7B1330"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Vaciar carrito"
                                    Width="130"
                                    Height="42"
                                    Margin="0,0,10,0"
                                    Background="White"
                                    BorderBrush="#CFA3B1"
                                    BorderThickness="2"
                                    Foreground="#7B1330"
                                    FontWeight="Bold"
                                    Click="BtnVaciarCarrito_Click"/>

                            <Button Content="Hacer pedido"
                                    Width="140"
                                    Height="42"
                                    Background="#7B1330"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="BtnHacerPedido_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>