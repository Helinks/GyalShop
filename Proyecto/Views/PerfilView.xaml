<UserControl x:Class="Proyecto.Views.PerfilView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="760"
    Width="1414">

    <Grid Background="#F5F1F2">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="40">

                <Grid Margin="0,0,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            Padding="30"
                            CornerRadius="20"
                            BorderBrush="#E8DCE1"
                            BorderThickness="1"
                            Margin="0,0,20,0">

                        <StackPanel>

                            <TextBlock Text="Mi Perfil"
                                       FontSize="38"
                                       FontWeight="Bold"
                                       Foreground="#5A0D24"/>

                            <TextBlock Text="Administra tu información y pedidos"
                                       FontSize="16"
                                       Margin="0,10,0,0"
                                       Foreground="#7B1330"/>

                        </StackPanel>

                    </Border>


                    <Button Grid.Column="1"
                            Content="← Volver al inicio"
                            Width="190"
                            Height="52"
                            VerticalAlignment="Center"
                            Background="#7B1330"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="15"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnVolverInicio_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">

                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>

                                </Border>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </Grid>

                <Border Background="White"
                        Padding="30"
                        CornerRadius="20"
                        BorderBrush="#E8DCE1"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Información personal"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#5A0D24"
                                   Margin="0,0,0,20"/>

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,15,0">

                                <TextBlock Text="Nombre"
                                           FontWeight="Bold"/>

                                <TextBox x:Name="txtNombre"
                                         Height="45"
                                         IsEnabled="False"
                                         Margin="0,8,0,18"/>

                            </StackPanel>

                            <StackPanel Grid.Column="1">

                                <TextBlock Text="Correo"
                                           FontWeight="Bold"/>

                                <TextBox x:Name="txtCorreo"
                                         Height="45"
                                         IsEnabled="False"
                                         Margin="0,8,0,18"/>

                            </StackPanel>

                        </Grid>

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,15,0">

                                <TextBlock Text="Teléfono"
                                           FontWeight="Bold"/>

                                <TextBox x:Name="txtTelefono"
                                         Height="45"
                                         IsEnabled="False"
                                         Margin="0,8,0,18"/>

                            </StackPanel>

                            <StackPanel Grid.Column="1">

                                <TextBlock Text="Dirección"
                                           FontWeight="Bold"/>

                                <TextBox x:Name="txtDireccion"
                                         Height="45"
                                         Margin="0,8,0,18"/>

                            </StackPanel>

                        </Grid>

                        <Button Content="Guardar dirección"
                                Width="220"
                                Height="52"
                                Background="#7B1330"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="15"
                                BorderThickness="0"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                Click="BtnGuardarDireccion_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="14">

                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>

                                    </Border>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                    </StackPanel>

                </Border>

                <Border Margin="0,25,0,0"
                        Background="White"
                        Padding="30"
                        CornerRadius="20"
                        BorderBrush="#E8DCE1"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Mis pedidos"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#5A0D24"
                                   Margin="0,0,0,20"/>

                        <DataGrid x:Name="dgPedidos"
                                  AutoGenerateColumns="False"
                                  Height="350"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  RowHeight="55"
                                  FontSize="14"
                                  Background="White"
                                  BorderThickness="0"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single" Width="1257">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"
                                            Value="#7B1330"/>

                                    <Setter Property="Foreground"
                                            Value="White"/>

                                    <Setter Property="FontWeight"
                                            Value="Bold"/>

                                    <Setter Property="FontSize"
                                            Value="14"/>

                                    <Setter Property="Height"
                                            Value="50"/>

                                    <Setter Property="BorderThickness"
                                            Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">

                                    <Setter Property="Background"
                                            Value="White"/>

                                    <Setter Property="BorderBrush"
                                            Value="#F0F0F0"/>

                                    <Setter Property="BorderThickness"
                                            Value="0,0,0,1"/>

                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="ID Pedido"
                                                    Binding="{Binding IdPedido}"
                                                    Width="150"/>

                                <DataGridTextColumn Header="Estado"
                                                    Binding="{Binding idEstadoPedido.IdEstado}"
                                                    Width="200"/>

                                <DataGridTextColumn Header="Usuario"
                                                    Binding="{Binding IdUsuarioPedido.IdUsuario}"
                                                    Width="200"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>