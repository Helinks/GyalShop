<UserControl x:Class="Proyecto.Views.PerfilView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="760"
    Width="1414">

    <Grid Background="#F5F1F2">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="32">

                <Grid Margin="0,0,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            Padding="28"
                            CornerRadius="20"
                            BorderBrush="#E8DCE1"
                            BorderThickness="1"
                            Margin="0,0,16,0">

                        <StackPanel>
                            <TextBlock Text="Mi Perfil"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="#5A0D24"/>

                            <TextBlock Text="Administra tu información y pedidos"
                                       FontSize="16"
                                       Margin="0,8,0,0"
                                       Foreground="#7B1330"/>
                        </StackPanel>
                    </Border>

                    <Button Grid.Column="1"
                            Content="← Volver al inicio"
                            Width="190"
                            Height="52"
                            VerticalAlignment="Center"
                            Background="#7B1330"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="15"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnVolverInicio_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Border Background="White"
                        Padding="28"
                        CornerRadius="20"
                        BorderBrush="#E8DCE1"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Información personal"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#5A0D24"
                                   Margin="0,0,0,18"/>

                        <Grid Margin="0,0,0,8">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="Nombre"
                                           FontWeight="Bold"
                                           Foreground="#374151"/>

                                <TextBox x:Name="txtNombre"
                                         Height="42"
                                         IsEnabled="False"
                                         Margin="0,8,0,16"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Correo"
                                           FontWeight="Bold"
                                           Foreground="#374151"/>

                                <TextBox x:Name="txtCorreo"
                                         Height="42"
                                         IsEnabled="False"
                                         Margin="0,8,0,16"/>
                            </StackPanel>
                        </Grid>

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="Teléfono"
                                           FontWeight="Bold"
                                           Foreground="#374151"/>

                                <TextBox x:Name="txtTelefono"
                                         Height="42"
                                         IsEnabled="False"
                                         Margin="0,8,0,16"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Dirección"
                                           FontWeight="Bold"
                                           Foreground="#374151"/>

                                <TextBox x:Name="txtDireccion"
                                         Height="42"
                                         Margin="0,8,0,16"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Guardar dirección"
                                Width="220"
                                Height="50"
                                Background="#7B1330"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="15"
                                BorderThickness="0"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                Click="BtnGuardarDireccion_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="14">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </Border>

                <Border Margin="0,25,0,0"
                        Background="White"
                        Padding="28"
                        CornerRadius="20"
                        BorderBrush="#E8DCE1"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Mis pedidos"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#5A0D24"
                                   Margin="0,0,0,18"/>

                        <DataGrid x:Name="dgPedidosDetalle"
                                  AutoGenerateColumns="False"
                                  MinHeight="320"
                                  Height="360"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="44"
                                  FontSize="14"
                                  Background="White"
                                  BorderThickness="0"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  HorizontalAlignment="Stretch"
                                  HorizontalScrollBarVisibility="Auto">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#7B1330"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Height" Value="44"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="8,0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Padding" Value="4"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Pedido"
                                                    Binding="{Binding IdPedido}"
                                                    Width="1*"/>

                                <DataGridTextColumn Header="Estado"
                                                    Binding="{Binding Estado}"
                                                    Width="1.3*"/>

                                <DataGridTextColumn Header="Producto"
                                                    Binding="{Binding NombreProducto}"
                                                    Width="3*"/>

                                <DataGridTextColumn Header="Precio"
                                                    Binding="{Binding PrecioProducto, StringFormat=$ {0:N0}}"
                                                    Width="1*"/>

                                <DataGridTextColumn Header="Cantidad"
                                                    Binding="{Binding CantidadProducto}"
                                                    Width="1*"/>

                                <DataGridTextColumn Header="Subtotal"
                                                    Binding="{Binding Subtotal, StringFormat=$ {0:N0}}"
                                                    Width="1*"/>

                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>