<UserControl x:Class="Proyecto.Views.ComprasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            
            <ColumnDefinition Width="2*"/>
            
            <ColumnDefinition Width="1*"/>
            
        </Grid.ColumnDefinitions>

        
        <StackPanel Grid.Column="0" Margin="0,0,20,0">

            <TextBlock Text="Productos Disponibles" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <DataGrid x:Name="dgProductos"
                      Height="200"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="dgProductos_SelectionChanged"
                      Margin="0,0,0,20">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="2*"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding CantidadProducto}" Width="*"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding PrecioProducto, StringFormat={}{0:C}}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Text="Contenido del Carrito" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <DataGrid x:Name="dgCarrito"
                      Height="200"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="dgProductoCarrito_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="2*"/>
                    <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad}" Width="0.5*"/>
                    <DataGridTextColumn Header="Precio U." Binding="{Binding PrecioUnidad, StringFormat={}{0:C}}" Width="*"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat={}{0:C}}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        
        <Border Grid.Column="1" Background="#F0F0F0" CornerRadius="10" Padding="15">
            <StackPanel>
                <TextBlock Text="Gestión de Compra" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

                
                <StackPanel x:Name="PanelEdicion" Visibility="Collapsed" Margin="0,0,0,15">
                    <TextBlock Text="Producto Seleccionado:" x:Name="nombreProductoLabel" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="nombreProducto" FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <TextBlock Text="Cantidad:" x:Name="cantidadProductoLabel" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <xctk:IntegerUpDown x:Name="numCantidad" 
                                        Height="30" 
                                        Minimum="0" 
                                        VerticalContentAlignment="Center"/>
                </StackPanel>

                
                <TextBox x:Name="txtNombre" Visibility="Collapsed" Height="30" Margin="0,0,0,10"/>

                
                <UniformGrid Columns="1" VerticalAlignment="Bottom">
                    <Button Content="Añadir al Carrito" 
                            x:Name="BtnAgregar" 
                            Click="AgregarCarrito" 
                            Height="35" Margin="0,0,0,10"
                            Background="#4CAF50" Foreground="White" FontWeight="Bold"
                            Visibility="Collapsed"/>

                    <Button Content="Guardar Cambios" 
                            x:Name="BtnActualizar" 
                            Click="BtnActualizar_Click" 
                            Height="35" Margin="0,0,0,10"
                            Background="#2196F3" Foreground="White" FontWeight="Bold"
                            Visibility="Collapsed"/>

                    <Button Content="Eliminar Item" 
                            x:Name="BtnEliminar" 
                            Click="BtnEliminar_Click" 
                            Height="35" Margin="0,0,0,10"
                            Background="#FF5722" Foreground="White" FontWeight="Bold"
                            Visibility="Collapsed"/>

                    <Button Content="Descartar" 
                            x:Name="BtnCancelar" 
                            Click="BtnCancelar_Click" 
                            Height="35" Margin="0,0,0,10"
                            Background="#9E9E9E" Foreground="White" FontWeight="Bold"
                            Visibility="Collapsed"/>

                    <Separator Margin="0,5,0,15" Background="#CCC"/>

                    <Button Content="Vaciar Carrito" 
                            x:Name="BtnEliminarCarrito" 
                            Click="BtnEliminarCarrito_Click" 
                            Height="35" Margin="0,0,0,10"
                            Background="#E91E63" Foreground="White" FontWeight="Bold"/>

                    <Button Content="Finalizar Compra" 
                            x:Name="BtnFinalizarCompra" 
                            Click="BtnFinalizarCompra_Click" 
                            Height="35"
                            Background="#7B1330" Foreground="White" FontWeight="Bold" />
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>