<UserControl x:Class="Proyecto.Views.SignUp"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="781"
    Width="1376"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <Grid Background="#F5F1F2">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="600" />
        </Grid.ColumnDefinitions>

        <!-- ===================== LEFT SIDE (IGUAL LOGIN) ===================== -->
        <Grid Grid.Column="0">

            <Image Source="/Assets/Images/banner.png"
                   Stretch="UniformToFill"/>

            <Border Background="#7B1330"
                    Opacity="0.72"/>

            <StackPanel VerticalAlignment="Center"
                        Margin="85"
                        HorizontalAlignment="Left">

                <TextBlock Text="Crea tu cuenta en GyalShop"
                           FontSize="54"
                           FontWeight="Bold"
                           Foreground="White"
                           Width="560"
                           TextWrapping="Wrap"/>

                <TextBlock Text="Únete y accede a productos premium de belleza, skincare y maquillaje con una experiencia única."
                           FontSize="20"
                           Foreground="White"
                           Width="520"
                           Margin="0,22,0,0"
                           Opacity="0.95"
                           TextWrapping="Wrap"/>

            </StackPanel>

        </Grid>

        <!-- ===================== RIGHT SIDE ===================== -->
        <Grid Grid.Column="1"
              Background="White">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <Border Width="490"
                        Margin="50"
                        Padding="30"
                        Background="White"
                        CornerRadius="24" Height="688">

                    <StackPanel>

                        <!-- TITLE -->
                        <TextBlock Text="Registro"
                                   FontSize="40"
                                   FontWeight="Bold"
                                   Foreground="#5A0D24"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Completa tus datos"
                                   FontSize="15"
                                   Foreground="#7B1330"
                                   Margin="0,8,0,30"
                                   HorizontalAlignment="Center"/>

                        <!-- NOMBRE -->
                        <TextBlock Text="Nombre"
                                   FontWeight="SemiBold"
                                   Foreground="#5A0D24"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtNombre"
                                 Height="45"
                                 FontSize="15"
                                 Margin="0,0,0,15"/>

                        <!-- CORREO -->
                        <TextBlock Text="Correo electrónico"
                                   FontWeight="SemiBold"
                                   Foreground="#5A0D24"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtCorreo"
                                 Height="45"
                                 FontSize="15"
                                 Margin="0,0,0,15"/>

                        <!-- PASSWORD -->
                        <TextBlock Text="Contraseña"
                                   FontWeight="SemiBold"
                                   Foreground="#5A0D24"
                                   Margin="0,0,0,6"/>
                        <PasswordBox x:Name="txtPassword"
                                     Height="45"
                                     FontSize="15"
                                     Margin="0,0,0,15"/>

                        <!-- TELEFONO -->
                        <TextBlock Text="Teléfono"
                                   FontWeight="SemiBold"
                                   Foreground="#5A0D24"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtTelefono"
                                 Height="45"
                                 FontSize="15"
                                 Margin="0,0,0,15"/>

                        <!-- DIRECCION -->
                        <TextBlock Text="Dirección"
                                   FontWeight="SemiBold"
                                   Foreground="#5A0D24"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtDireccion"
                                 Height="45"
                                 FontSize="15"
                                 Margin="0,0,0,25"/>

                        <!-- BOTÓN REGISTRO -->
                        <Button Content="Crear cuenta"
                                Height="55"
                                Background="#7B1330"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="16"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnRegister_Click"/>

                        <!-- IR LOGIN -->
                        <Button Content="Ya tengo cuenta"
                                Margin="0,15,0,0"
                                Background="Transparent"
                                Foreground="#7B1330"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnLogin_Click"/>

                    </StackPanel>

                </Border>

            </ScrollViewer>

        </Grid>

    </Grid>

</UserControl>