<UserControl x:Class="Proyecto.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="300" d:DesignWidth="400" Height="766"
    Width="1414">

    <Grid Background="#F3F4F6">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
        Background="White"
        BorderBrush="#E8DCE1"
        BorderThickness="0,0,0,1">

            <Grid Margin="50,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>


                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Image Source="/Assets/Images/logo.jpeg"
                       Width="136"
                       Height="71"
                       Stretch="Uniform"/>

                    <StackPanel Margin="12,0,0,0"
                        VerticalAlignment="Center">
                    </StackPanel>

                </StackPanel>

                <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <Button Content="Inicio"
                    Width="100"
                    Height="42"
                    Margin="0,0,8,0"
                    Background="Transparent"
                    Foreground="#5A0D24"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    FontSize="15"
                    Cursor="Hand"/>


                    <Button Content="Productos"
                    Width="120"
                    Height="42"
                    Margin="0,0,8,0"
                    Background="Transparent"
                    Foreground="#5A0D24"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    FontSize="15"
                    Cursor="Hand"/>


                    <Button Content="Ofertas"
                    Width="100"
                    Height="42"
                    Margin="0,0,15,0"
                    Background="Transparent"
                    Foreground="#5A0D24"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    FontSize="15"
                    Cursor="Hand"/>

                    <Button  x:Name="BtnLogin" 
                    Width="150"
                    Height="48"
                    Background="#7B1330"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    FontSize="15"
                    Cursor="Hand"
                    Click="BtnLogin_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">

                                    <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                                </Border>

                            </ControlTemplate>
                        </Button.Template>

                        Iniciar Sesión

                    </Button>

                    <Button x:Name="BtnPerfi"
                        Width="150"
                        Height="48"
                        Background="#7B1330"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        FontSize="15"
                        Cursor="Hand"
                        Visibility="Collapsed"
                       >

                        Perfil
                    </Button>

                </StackPanel>

            </Grid>

        </Border>

        <Grid Grid.Row="1">

            <Image Source="/Assets/Images/banner.png"
                Stretch="UniformToFill"/>

            <Grid Margin="50,0,0,0"
                HorizontalAlignment="Left">

                <StackPanel Width="720"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left">

                    <Border Background="#CFA3B1"
                    Width="240"
                    Height="42"
                    CornerRadius="25"
                    HorizontalAlignment="Left">

                        <TextBlock Text="BEAUTY • MAKEUP • SKINCARE"
                           Foreground="#5A0D24"
                           FontWeight="Bold"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                    </Border>

                    <!-- TITULO -->

                    <TextBlock Text="Realza tu belleza con maquillaje premium"
                       FontSize="72"
                       FontWeight="Bold"
                       Foreground="#5A0D24"
                       Margin="0,25,0,0"
                       TextWrapping="Wrap"
                       TextAlignment="Left"/>


                    <TextBlock Text="Descubre productos exclusivos de maquillaje, skincare y belleza diseñados para hacerte sentir segura, elegante y auténtica todos los días."
                       FontSize="22"
                       Margin="0,28,0,0"
                       Foreground="#7B1330"
                       Opacity="0.90"
                       Width="650"
                       TextWrapping="Wrap"
                       TextAlignment="Left"/>

                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="0,55,0,0">

                        <Button Width="240"
                        Height="66"
                        Background="#7B1330"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        FontSize="16"
                        Cursor="Hand"
                        Margin="0,0,20,0">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border Background="{TemplateBinding Background}"
                                    CornerRadius="16">

                                        <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>

                                    </Border>

                                </ControlTemplate>
                            </Button.Template>

                            Comprar ahora

                        </Button>

                        <Button Width="240"
                        Height="66"
                        Background="White"
                        BorderBrush="#CFA3B1"
                        BorderThickness="2"
                        Foreground="#7B1330"
                        FontWeight="Bold"
                        FontSize="16"
                        Cursor="Hand">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16">

                                        <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>

                                    </Border>

                                </ControlTemplate>
                            </Button.Template>

                            Explorar colección

                        </Button>

                    </StackPanel>

                </StackPanel>

            </Grid>

        </Grid>

    </Grid>

</UserControl>