<UserControl x:Class="Proyecto.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Proyecto.Converters"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400"
             Height="766"
             Width="1414"
             Loaded="HomeView_Loaded">

    <UserControl.Resources>
        <conv:ImgConverter x:Key="ImagePathConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F4F6">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E8DCE1"
                BorderThickness="0,0,0,1">

            <Grid Margin="50,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Image Source="/Assets/Images/logo.jpeg"
                           Width="136"
                           Height="71"
                           Stretch="Uniform"/>

                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button Content="Inicio"
                            Width="100"
                            Height="42"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            Foreground="#5A0D24"
                            FontWeight="SemiBold"
                            FontSize="15"
                            Click="BtnInicio_Click"/>

                    <Button Content="Productos"
                            Width="120"
                            Height="42"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            Foreground="#5A0D24"
                            FontWeight="SemiBold"
                            FontSize="15"
                            Click="BtnProductos_Click"/>

                    <Button Content="Carrito"
                            Width="100"
                            Height="42"
                            Margin="0,0,15,0"
                            Background="Transparent"
                            Foreground="#5A0D24"
                            FontWeight="SemiBold"
                            FontSize="15"
                            Click="BtnCarrito_Click"/>

                    <Button x:Name="BtnLogin"
                            Width="150"
                            Height="48"
                            Background="#7B1330"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="15"
                            Margin="0,0,10,0"
                            Click="BtnLogin_Click">
                        Iniciar Sesión
                    </Button>

                    <Button x:Name="BtnPerfi"
                            Width="150"
                            Height="48"
                            Background="#7B1330"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="15"
                            Visibility="Collapsed"
                            Click="BtnPerfil_Click">
                        Perfil
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel>

                <!-- HERO -->
                <Grid Height="560">
                    <Image Source="/Assets/Images/banner.png"
                           Stretch="UniformToFill"/>

                    <Grid Margin="50,0,0,0"
                          HorizontalAlignment="Left">

                        <StackPanel Width="720"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left">

                            <Border Background="#CFA3B1"
                                    Width="240"
                                    Height="42"
                                    CornerRadius="25"
                                    HorizontalAlignment="Left">

                                <TextBlock Text="BEAUTY • MAKEUP • SKINCARE"
                                           Foreground="#5A0D24"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Realza tu belleza con maquillaje premium"
                                       FontSize="72"
                                       FontWeight="Bold"
                                       Foreground="#5A0D24"
                                       Margin="0,25,0,0"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Descubre productos exclusivos de maquillaje, skincare y belleza diseñados para hacerte sentir segura, elegante y auténtica todos los días."
                                       FontSize="22"
                                       Margin="0,28,0,0"
                                       Foreground="#7B1330"
                                       Opacity="0.90"
                                       Width="650"
                                       TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="0,55,0,0">

                                <Button Width="240"
                                        Height="66"
                                        Background="#7B1330"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="16"
                                        Margin="0,0,20,0"
                                        Click="BtnComprarAhora_Click">
                                    Comprar ahora
                                </Button>

                                <Button Width="240"
                                        Height="66"
                                        Background="White"
                                        BorderBrush="#CFA3B1"
                                        BorderThickness="2"
                                        Foreground="#7B1330"
                                        FontWeight="Bold"
                                        FontSize="16"
                                        Click="BtnExplorar_Click">
                                    Explorar colección
                                </Button>

                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- CATEGORY SECTION -->
                <StackPanel Margin="50,28,50,0">
                    <TextBlock Text="Categorías"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#5A0D24"
                               Margin="0,0,0,14"/>

                    <ItemsControl x:Name="icCategorias">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding NombreCategoria}"
                                        Tag="{Binding IdCategoria}"
                                        Click="BtnCategoria_Click"
                                        Margin="0,0,12,12"
                                        Padding="18,10"
                                        Background="White"
                                        Foreground="#7B1330"
                                        BorderBrush="#E8DCE1"
                                        BorderThickness="1"
                                        FontWeight="SemiBold"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- PRODUCTS -->
                <StackPanel Margin="50,20,50,0">
                    <TextBlock Text="Productos destacados"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#5A0D24"
                               Margin="0,0,0,14"/>

                    <ItemsControl x:Name="icProductos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="280"
                                        Margin="0,0,18,18"
                                        Background="White"
                                        CornerRadius="18"
                                        Padding="18"
                                        BorderBrush="#E8DCE1"
                                        BorderThickness="1">

                                    <StackPanel>

                                        <Border Height="170"
                                                CornerRadius="14"
                                                Background="#FAFAFA"
                                                Margin="0,0,0,12">
                                            <Image Source="{Binding ImagenProducto, Converter={StaticResource ImagePathConverter}}"
                                                   Stretch="UniformToFill"/>
                                        </Border>

                                        <TextBlock Text="{Binding NombreProducto}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#5A0D24"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding IdCategoriaProducto.NombreCategoria}"
                                                   Margin="0,6,0,0"
                                                   Foreground="#7B1330"
                                                   Opacity="0.85"/>

                                        <TextBlock Text="{Binding CantidadProducto, StringFormat=Stock: {0}}"
                                                   Margin="0,6,0,0"
                                                   Foreground="#444"/>

                                        <TextBlock Text="{Binding PrecioFinal, StringFormat=Precio: $ {0:N0}}"
                                                   Margin="0,6,0,0"
                                                   Foreground="#111"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Text="{Binding DescuentoProducto, StringFormat=Descuento: {0}%}"
                                                   Margin="0,6,0,14"
                                                   Foreground="#7B1330"/>

                                        <Button Content="Agregar al carrito"
                                                Tag="{Binding}"
                                                Click="BtnAgregarCarrito_Click"
                                                Height="42"
                                                Background="#7B1330"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontWeight="Bold"/>
                                    </StackPanel>

                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- DESCRIPTION SECTION -->
                <Border Margin="50,10,50,0"
                        Background="White"
                        CornerRadius="18"
                        Padding="24"
                        BorderBrush="#E8DCE1"
                        BorderThickness="1">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Tu tienda de belleza favorita"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#5A0D24"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Explora maquillaje, skincare y productos pensados para tu rutina diaria. Compra rápido, guarda en tu carrito y finaliza tu pedido cuando estés listo."
                                       FontSize="16"
                                       Foreground="#4B5563"
                                       TextWrapping="Wrap"
                                       LineHeight="24"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Beneficios"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#5A0D24"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="• Productos con imagen y categoría."
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="• Carrito listo para pedido."
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="• Acceso a login o perfil según sesión."
                                       Margin="0,0,0,6"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- FOOTER -->
                <Border Margin="0,24,0,0"
                        Background="#5A0D24"
                        Padding="28">

                    <Grid Margin="50,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="DilNic"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Belleza, estilo y confianza en un solo lugar."
                                       Foreground="#F3F4F6"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Secciones"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Inicio" Foreground="#F3F4F6"/>
                            <TextBlock Text="Productos" Foreground="#F3F4F6"/>
                            <TextBlock Text="Categorías" Foreground="#F3F4F6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Contacto"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Soporte y pedidos" Foreground="#F3F4F6"/>
                            <TextBlock Text="Atención al cliente" Foreground="#F3F4F6"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>