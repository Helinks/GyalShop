<UserControl x:Class="Proyecto.Views.CategoriaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LISTADO -->
        <DataGrid x:Name="dgCategorias"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="dgCategorias_SelectionChanged"
                  Margin="0,0,20,0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Categoria" Binding="{Binding NombreCategoria}" Width="450"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- FORMULARIO -->
        <StackPanel Grid.Column="1" Margin="20" Height="329">

            <TextBlock Text="Gestión de Categorias"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Nombre -->
            <TextBlock Text="Nombre de categoria" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNombre"
                     Height="35"
                     Margin="0,0,0,12"/>
            
            


            <!-- Botones -->
            <StackPanel Orientation="Horizontal">

                <Button Content="Guardar"
                        x:Name="BtnGuardar"
                        Click="BtnGuardar_Click"
                        Width="100"
                        Margin="0,0,10,0"/>
                <Button Content="Cancelar"
                        x:Name="BtnCancelar"
                        Click="BtnCancelar_Click"
                        Width="100"
                        Margin="0,0,10,0"
                        Visibility="Collapsed"/>

                <Button Content="Actualizar"
                        x:Name="BtnActualizar"
                        Click="BtnActualizar_Click"
                        Width="100"
                        Margin="0,0,10,0"
                        Visibility="Collapsed"/>

                <Button Content="Eliminar"
                        x:Name="BtnEliminar"
                        Click="BtnEliminar_Click"
                        Width="100"
                        Visibility="Collapsed"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</UserControl>