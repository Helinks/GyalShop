<UserControl x:Class="Proyecto.Views.Login"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="694"
    Width="1438">

    <Grid Background="#F5F1F2" Margin="0,0,10,0">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="620"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->

        <Grid>

            <Image Source="/Assets/Images/banner.png"
                   Stretch="UniformToFill"/>

            <Border Background="#7B1330"
                    Opacity="0.72"/>

            <StackPanel VerticalAlignment="Center"
                        Margin="90">

                <TextBlock Text="Bienvenida a GyalShop"
                           FontSize="55"
                           FontWeight="Bold"
                           Foreground="White"
                           Width="671"/>

                <TextBlock Text="Accede a productos premium de maquillaje, skincare y belleza desde un solo lugar."
                           FontSize="24"
                           Foreground="White"
                           Width="560"
                           Margin="0,25,0,0"
                           Opacity="0.95"
                           TextWrapping="Wrap"/>

            </StackPanel>

        </Grid>

        <!-- RIGHT SIDE -->

        <Grid Grid.Column="1"
              Background="White"
              Margin="0,0,10,0">

            <!-- BOTÓN VOLVER -->

            <Button Content="← Volver al inicio"
                    Width="160"
                    Height="42"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="30,30,0,0"
                    Background="Transparent"
                    Foreground="#7B1330"
                    FontWeight="Bold"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnVolver_Click"/>

            <Border Width="430"
                    Padding="20"
                    Background="White"
                    CornerRadius="24"
                    VerticalAlignment="Center">

                <StackPanel>

                    <!-- TITLE -->

                    <TextBlock Text="Iniciar Sesión"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="#5A0D24"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Ingresa tus datos para continuar"
                               FontSize="16"
                               Foreground="#7B1330"
                               Margin="0,10,0,35"
                               HorizontalAlignment="Center"/>

                    <!-- EMAIL -->

                    <TextBlock Text="Correo electrónico"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#5A0D24"
                               Margin="0,0,0,8"/>

                    <Border Background="#F7F4F5"
                            BorderBrush="#E4D7DC"
                            BorderThickness="1"
                            CornerRadius="14">

                        <TextBox x:Name="txtCorreo"
                                 Height="54"
                                 FontSize="16"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="18,0"/>
                    </Border>

                    <!-- PASSWORD -->

                    <TextBlock Text="Contraseña"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#5A0D24"
                               Margin="0,24,0,8"/>

                    <Border Background="#F7F4F5"
                            BorderBrush="#E4D7DC"
                            BorderThickness="1"
                            CornerRadius="14">

                        <PasswordBox x:Name="txtPassword"
                                     Height="54"
                                     FontSize="16"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="18,0"/>
                    </Border>

                    <!-- LOGIN BUTTON -->

                    <Button Content="Ingresar"
                            Height="60"
                            Margin="0,38,0,0"
                            Background="#7B1330"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="16"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnLogin_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="15">

                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>

                                </Border>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                    <!-- REGISTER -->

                    <Button Content="Crear cuenta"
                            Height="50"
                            Margin="0,18,0,0"
                            Background="Transparent"
                            Foreground="#7B1330"
                            FontWeight="Bold"
                            FontSize="15"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnRegister_Click"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</UserControl>