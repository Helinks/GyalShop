<UserControl x:Class="Proyecto.Views.PedidosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="dgPedidos"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="dgPedido_SelectionChanged"
                  Margin="0,0,250,0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Id del pedido" Binding="{Binding IdPedido}" Width="70"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding IdEstadoPedido.DescEstado}" Width="70"/>
            </DataGrid.Columns>

        </DataGrid>
        <DataGrid x:Name="dgProductosPedido"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          SelectionMode="Single"
          Margin="200,0,0,0" HorizontalAlignment="Left" Width="242">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Producto" Binding="{Binding Producto.NombreProducto}" Width="60"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadProducto}" Width="65"/>
                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal}" Width="70"/>
            </DataGrid.Columns>

        </DataGrid>


        <StackPanel Grid.Column="1" Margin="20" Height="329">

            <TextBlock Text="Carrito"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20" Width="301"/>


            
            <TextBlock x:Name="cantidadProductoLabel" Text="Cambiar estado:" Margin="0,0,0,5" Visibility="Collapsed"/>
			<ComboBox
				x:Name="cmEstado"
				Margin="0,0,0,12"
				Height="35"
				DisplayMemberPath="DescEstado"
                              SelectedValuePath="IdEstado"
				Visibility="Collapsed"
				/>
            <TextBox x:Name="txtNombre"
                     Height="35"
                     Margin="0,0,0,12"
                     Visibility="Collapsed"/>





            <StackPanel Orientation="Horizontal">

                <Button Content="Cambiar Estado"
                        x:Name="BtnEstado"
                        Click="CambiarEstadoPedido"
                        Width="100"
                        Margin="0,0,10,0"
                        Visibility="Collapsed"/>
                <Button Content="Cancelar"
                        x:Name="BtnCancelar"
                        Click="BtnCancelar_Click"
                        Width="100"
                        Margin="0,0,10,0"
                        Visibility="Collapsed"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</UserControl>